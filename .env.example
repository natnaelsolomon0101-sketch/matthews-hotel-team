# =============================================================================
# Matthews Hotel Team — environment variables
# Copy to .env.local for local dev, set in Vercel for production.
# =============================================================================

# HubSpot Forms API (inbound contact pipe)
# ---------------------------------------------------------
# These two values are required for /api/contact to push form submissions
# into HubSpot as inbound leads. Both are publicly visible (HubSpot's Forms
# API is unauthenticated by design — the GUID itself is the identifier).
#
# Where to find them:
#   1. HubSpot account ID (portal ID): top-right account menu → "Account name"
#      panel shows "Hub ID: XXXXXXXX". Copy the digits.
#   2. Form GUID: Marketing → Forms → "Matthews Hotel Team — Contact" (or
#      whatever you name it) → Edit → Embed code → grab the form id.
#
# When set:
#   - submissions hit HubSpot, marked with `lead_source_detail =
#     "Website — Matthews Hotel Team"`.
# When unset:
#   - the route returns 503 with code "HUBSPOT_NOT_CONFIGURED"; the form
#     falls back to mailto so the contact path still works.

HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=
